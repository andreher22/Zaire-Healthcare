# ====================================
# ZAIRE Healthcare - Variables de Entorno
# ====================================
# Copia este archivo como .env y configura tus valores

# Django
SECRET_KEY=tu-clave-secreta-aqui-genera-una-nueva
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

# Base de Datos - SQL Server Express (Local)
DB_ENGINE=mssql
DB_NAME=zaire_healthcare
DB_USER=sa
DB_PASSWORD=tu_password_sql_server
DB_HOST=localhost
DB_PORT=1433

# Base de Datos - Azure SQL Database (Producción)
# DB_HOST=tu-servidor.database.windows.net
# DB_USER=tu-usuario-azure
# DB_PASSWORD=tu-password-azure
# DB_NAME=zaire_healthcare

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# IA
MODEL_PATH=apps/diagnostico/ml/modelos_guardados/
